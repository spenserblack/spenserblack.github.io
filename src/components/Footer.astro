---
import ExternalLink from "./ExternalLink.astro";
import SocialLogos from "./SocialLogos.astro";
const email = "me@spenser.black";
const bluesky = "https://bsky.app/profile/spenser.black";
const codeberg = "https://codeberg.org/spenserblack";
const github = "https://github.com/spenserblack";
const tangled = "https://tangled.org/spenser.black";
const sourceCode = `${github}/spenserblack.github.io`;
---

<footer>
	<h2>Links</h2>
	<ul class="horizontal">
		<li>
			<strong>Contacts and socials</strong>
			<ul class="vertical">
				<li><a href={`mailto:${email}`}>{email}</a></li>
				<li>
					<SocialLogos
						brand="Bluesky"
						dark="bluesky_media_kit_logo_transparent_3.svg"
						light="bluesky_media_kit_logo_transparent_4.svg"
					/>
					<ExternalLink link={bluesky}>Bluesky</ExternalLink>
				</li>
				<li>
					<SocialLogos
						brand="Codeberg"
						dark="codeberg-logo_icon_white.svg"
						light="codeberg-logo_special_fake-transaprency.svg"
					/>
					<ExternalLink link={codeberg}>Codeberg</ExternalLink>
				</li>
				<li>
					<SocialLogos
						brand="GitHub"
						dark="GitHub_Invertocat_White.svg"
						light="GitHub_Invertocat_Black.svg"
					/>
					<ExternalLink link={github}>GitHub</ExternalLink>
				</li>
				<li>
					<SocialLogos
						brand="Tangled"
						dark="tangled_dolly_face_white.svg"
						light="tangled_dolly_face_black.svg"
					/>
					<ExternalLink link={tangled}>Tangled</ExternalLink>
				</li>
			</ul>
		</li>
		<li>
			<strong>Other</strong>
			<ul class="vertical">
				<li><ExternalLink link={sourceCode}>Site source code</ExternalLink></li>
			</ul>
		</li>
	</ul>
</footer>

<style>
	ul {
		display: flex;
		justify-content: space-around;
	}
	ul.horizontal {
		/* NOTE Make Don't display items horizontally unless the screen is wide enough. */
		flex-direction: column;
	}
	@media (min-width: 640px) {
		ul.horizontal {
			flex-direction: row;
		}
	}
	ul.vertical {
		flex-direction: column;
	}
	li {
		display: inline-block;
		flex-direction: column;
		margin: 0 0.5rem;
	}
</style>
