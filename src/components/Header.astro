---
const pages: [description: string, link: string][] = [
	["Homepage", "/"],
	["Projects", "/projects/"],
	["Markdown for Steam", "/steamdown/"],
];
---

<header>
	<div class="dropdown-container">
		<button
			aria-expanded="false"
			aria-controls="nav-menu"
			id="nav-menu-button"
			class="primary">Navigation</button
		>
		<nav id="nav-menu">
			{
				pages.map(([description, link]) => (
					<a class="button primary" href={link}>
						{description}
					</a>
				))
			}
		</nav>
	</div>
	<div class="controls">
		<div id="theme-dropdown" class="dropdown">
			<button
				type="button"
				id="theme-dropdown-button"
				class="primary theme"
				aria-expanded="false"
				aria-controls="theme-dropdown"
			>
				Theme
			</button>
			<ul id="theme-dropdown-content" class="dropdown-content hide">
				<li><button type="button" id="theme-system">System</button></li>
				<li><button type="button" id="theme-dark">Dark</button></li>
				<li><button type="button" id="theme-light">Light</button></li>
			</ul>
		</div>
	</div>
</header>

<script>
	const button = document.getElementById(
		"nav-menu-button",
	) as HTMLButtonElement;
	const menu = document.getElementById("nav-menu") as HTMLElement;
	const cls = "expanded";
	button.addEventListener("click", () => {
		if (menu.classList.contains(cls)) {
			menu.classList.remove(cls);
			button.setAttribute("aria-expanded", "false");
		} else {
			menu.classList.add(cls);
			button.setAttribute("aria-expanded", "true");
		}
	});
</script>
<script>
	import "../scripts/theme-dropdown";
</script>

<style>
	header {
		display: flex;
		flex-direction: row;
		justify-content: space-around;
	}
	.dropdown ul {
		position: fixed;
		padding: 0;
		background-color: var(--contrast);
		margin-top: 0.1rem;
	}
	.dropdown ul li {
		display: block;
	}
	.dropdown ul li * {
		color: var(--main-fg);
		background-color: var(--contrast);
	}

	#nav-menu-button {
		display: none;
	}
	nav a {
		margin: 0 0.5rem;
	}
	@media screen and (max-width: 999px) {
		#nav-menu-button {
			display: unset;
		}
		nav.expanded {
			display: flex;
			flex-direction: column;
			margin-top: 0.5rem;
		}

		nav a {
			margin-bottom: 0.5rem;
		}
	}
	nav {
		display: none;
	}
	@media screen and (min-width: 1000px) {
		nav {
			display: unset;
		}
	}
</style>
