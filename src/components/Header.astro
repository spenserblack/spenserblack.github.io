---
const pages: [description: string, link: string][] = [
	["Homepage", "/"],
	["Projects", "/projects/"],
];
---
<header>
	<nav>
		{
			pages.map(([description, link]) => <a class="button primary" href={link}>{description}</a>)
		}
	</nav>
	<div class="controls">
		<div id="theme-dropdown" class="dropdown">
			<button type="button" id="theme-dropdown-button" class="primary theme" aria-expanded="false" aria-controls="theme-dropdown">
				Theme
			</button>
			<ul id="theme-dropdown-content" class="dropdown-content hide">
				<li><button type="button" id="theme-system">System</button></li>
				<li><button type="button" id="theme-dark">Dark</button></li>
				<li><button type="button" id="theme-light">Light</button></li>
			</ul>
		</div>
	</div>
</header>

<script>
	import "../scripts/theme-dropdown";
</script>

<style>
	header {
		display: flex;
		flex-direction: row;
		justify-content: space-around;
	}
	.dropdown ul {
		position: fixed;
		padding: 0;
		background-color: var(--contrast);
		margin-top: 0.1rem;
	}
	.dropdown ul li {
		display: block;
	}
	.dropdown ul li * {
		color: var(--main-fg);
		background-color: var(--contrast);
	}

	nav a {
		margin: 0 0.5rem;
	}
</style>
