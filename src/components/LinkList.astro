---
import ExternalLink from "./ExternalLink.astro";

type Item = {
	link: string;
	name: string;
	external?: boolean;
};
type Props = {
	items: Item[];
};

const { items } = Astro.props;
---
<ul>
	{
		items.map(({ link, name, external }) => <li>{
			external
			? <ExternalLink link={link}>{name}</ExternalLink>
			: <a href={link}>{name}</a>
		}</li>)
	}
</ul>
