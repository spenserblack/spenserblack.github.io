---
import BaseLayout from "../layouts/BaseLayout.astro";
import ExternalLink from "../components/ExternalLink.astro";
import LinkList from "../components/LinkList.astro";
const title = "Homepage";

const mapToExternalLinks = (items: Record<string, string>) =>
	Object.entries(items).map(([name, link]) => ({ name, link, external: true }));

const languages = mapToExternalLinks({
	Go: "https://go.dev/",
	Python: "https://www.python.org/",
	Ruby: "https://www.ruby-lang.org/",
	Rust: "https://rust-lang.org/",
	TypeScript: "https://www.typescriptlang.org/",
});

const books = mapToExternalLinks({
	Frankenstein: "https://en.wikipedia.org/wiki/Frankenstein",
	"Water Margin": "https://en.wikipedia.org/wiki/Water_Margin",
});
const animeAndManga = mapToExternalLinks({
	Baki: "https://youtu.be/vazrSoijLmA",
	Drifters: "https://en.wikipedia.org/wiki/Drifters_(manga)",
	"Getter Robo Armageddon":
		"https://en.wikipedia.org/wiki/Getter_Robo_Armageddon",
});
const games = mapToExternalLinks({
	"Resident Evil": "https://en.wikipedia.org/wiki/Resident_Evil",
	Signalis: "https://en.wikipedia.org/wiki/Signalis",
	Ys: "https://en.wikipedia.org/wiki/Ys_(series)",
});
---

<BaseLayout title={title}>
	<p>
		👋 This is my personal site. Why did I make a personal site? For these
		reasons:
	</p>
	<ul>
		<li>
			Give myself an excuse to buy the <a href="//spenser.black"
				><code>spenser.black</code></a
			> domain.
		</li>
		<li>
			Teach myself <ExternalLink link="https://astro.build/">Astro</ExternalLink
			>.
		</li>
	</ul>

	<h2>Introduction</h2>
	<p>
		I'm a developer, both for work and as a hobby, and I enjoy using the
		following languages:
	</p>
	<LinkList items={languages} />
	<p>
		As you can probably tell from this site's styling, I am not much of a <ExternalLink
			link="https://en.wikipedia.org/wiki/Front_end_and_back_end"
			>front-end</ExternalLink
		> developer, and tend to keep my websites simple. When I <em>do</em> write frontend
		stuff, I typically use either <ExternalLink link="https://svelte.dev/"
			>Svelte</ExternalLink
		> or <ExternalLink link="https://vuejs.org/">Vue</ExternalLink>. This site
		has been written with <strong
			><ExternalLink link="https://astro.build/">Astro</ExternalLink></strong
		>, since it seemed like a good tool to build a static site.
	</p>

	<p>
		Besides coding stuff, I like reading, video games, movies, anime and manga,
		and sometimes working out. I especially like:
	</p>
	<ul>
		<li>
			Books:
			<LinkList items={books} />
		</li>
		<li>
			Video Games:
			<LinkList items={games} />
		</li>
		<li>
			Anime/Manga
			<LinkList items={animeAndManga} />
		</li>
	</ul>
</BaseLayout>
