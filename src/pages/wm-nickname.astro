---
import BaseLayout from "../layouts/BaseLayout.astro";
import WmNickname from "../components/WmNickname.svelte";
const title = "Water Margin nickname generator";
---

<BaseLayout title={title}>
	<p>
		This is a nickname generator inspired by the nicknames of the 108 heroes of
		my favorite book, Water Margin. Pick a type of nickname generator and then
		generate your nickname!
	</p>
	<WmNickname client:only="svelte" />
</BaseLayout>
